# Variáveis de ambiente para coleta de dados
# Copie para .env e preencha os valores reais

# Portal da Transparência — Emendas Parlamentares
# Cadastro gratuito em: https://portaldatransparencia.gov.br/api-de-dados/cadastrar-email
TRANSPARENCIA_API_TOKEN=seu_token_aqui

# Base dos Dados (opcional, para dados preparados)
# Instruções em: https://basedosdados.org/docs/access_data_packages
# BASEDOSDADOS_PROJECT_ID=seu_projeto_gcp
